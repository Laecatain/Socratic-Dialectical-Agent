# 苏格拉底辩证智能体 环境变量配置
# 复制此文件为 .env 并填入实际值

# ---------- LLM 对话模型 ----------
OPENAI_API_KEY=sk-your-deepseek-api-key
OPENAI_API_BASE=https://api.deepseek.com/v1
OPENAI_MODEL_NAME=deepseek-v4-flash

# ---------- Embedding 向量模型（独立配置，支持不同的 API 网关） ----------
# 若与 LLM 使用同一网关，可留空（自动回退到 OPENAI_*）
# DeepSeek 不支持 Embedding，请在此处填入支持 embedding 的 API 地址
# 阿里云百炼 DashScope（OpenAI 兼容）
EMBEDDING_API_KEY=sk-your-key
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode
EMBEDDING_MODEL_NAME=text-embedding-v4
# 也可用 OpenAI: https://api.openai.com/v1 + text-embedding-3-small

# ---------- Web Search（动态知识流） ----------
# Tavily Search API — https://tavily.com
TAVILY_API_KEY=sk-your-tavily-key
# ChromaDB 余弦距离阈值（0~2，越小越严格，默认 0.5）
SIMILARITY_THRESHOLD=0.5
