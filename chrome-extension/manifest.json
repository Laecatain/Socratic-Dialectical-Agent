{
  "manifest_version": 3,
  "name": "苏格拉底辩证助手",
  "version": "1.0",
  "description": "划词选中文本，右键使用苏格拉底模式质询",
  "permissions": [
    "sidePanel",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}