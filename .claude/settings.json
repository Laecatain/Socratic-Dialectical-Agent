{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./.venv/Scripts/python.exe .claude/hook_ruff.py check",
            "shell": "bash",
            "statusMessage": "Linting edited Python files with ruff"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./.venv/Scripts/python.exe .claude/hook_ruff.py format-check",
            "shell": "bash",
            "statusMessage": "Checking edited Python file formatting"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "./.venv/Scripts/python.exe -m pytest tests/ --cov=nodes --cov=retriever_node --cov=state --cov=graph --cov=web_search_node --cov-report=term-missing",
            "shell": "bash",
            "statusMessage": "Running tests and coverage before session end"
          }
        ]
      }
    ]
  },
  "allowedTools": [
    "Read",
    "Write",
    "Edit",
    "Glob",
    "Grep",
    "Bash",
    "PowerShell",
    "TodoWrite",
    "TaskOutput",
    "TaskStop",
    "Agent",
    "AskUserQuestion",
    "WebFetch",
    "WebSearch"
  ]
}
